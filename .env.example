# DevMind Environment Variables
# Copy this file to .env and fill in your API keys.

# ── Required (get for free at https://console.groq.com) ──────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Optional Fallback (https://aistudio.google.com/app/apikey) ───────────────
GOOGLE_API_KEY=your_google_api_key_here
